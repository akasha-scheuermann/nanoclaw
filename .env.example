ASSISTANT_HAS_OWN_NUMBER=

# Cross-agent call visibility — forward call previews to source group's chat
# Set to "false" to disable. Enabled by default.
# CROSS_AGENT_VISIBILITY=true

# Comma-separated list of group folders that cannot be called via cross-agent IPC.
# Main groups are always restricted by default regardless of this setting.
# CROSS_AGENT_RESTRICTED_GROUPS=

# iMessage channel (optional) — requires macOS with Messages.app
# Install: git clone https://github.com/steipete/imsg && cd imsg && make build
# Grant Full Disk Access to the binary in System Settings → Privacy
# IMSG_PATH=/usr/local/bin/imsg

# Plex (optional) — media server tools via plex-mcp-server (Python, runs via uvx)
# Get your token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
# PLEX_TOKEN=your-plex-token
# PLEX_URL=http://192.168.1.100:32400
# PLEX_BLOCKED_TOOLS=playlist_delete,client_control_playback  # comma-separated tool names to block

# Fastmail (optional) — in-container JMAP email tools via fastmail-mcp-server
# Get an API token at: https://www.fastmail.com/settings/security/tokens
# FASTMAIL_API_TOKEN=fmu1-...
# FASTMAIL_BLOCKED_TOOLS=send_email,mark_as_spam  # comma-separated tool names to block
