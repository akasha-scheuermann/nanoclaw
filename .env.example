ASSISTANT_HAS_OWN_NUMBER=

# Cross-agent call visibility — forward call previews to source group's chat
# Set to "false" to disable. Enabled by default.
# CROSS_AGENT_VISIBILITY=true

# Comma-separated list of group folders that cannot be called via cross-agent IPC.
# Main groups are always restricted by default regardless of this setting.
# CROSS_AGENT_RESTRICTED_GROUPS=

# iMessage channel (optional) — requires macOS with Messages.app
# Install: git clone https://github.com/steipete/imsg && cd imsg && make build
# Grant Full Disk Access to the binary in System Settings → Privacy
# IMSG_PATH=/usr/local/bin/imsg
